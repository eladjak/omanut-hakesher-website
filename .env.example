# ===========================================
# Environment Variables for Omanut HaKesher
# ===========================================
# Copy this file to .env.local and fill in values

# Google Analytics
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Contact Form - Resend Email Service
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_EMAIL=hello@omanut-hakesher.co.il

# ===========================================
# Rav-Messer (Responder) V2 OAuth — for /api/lead/subscribe
# Account 1001688. Used to add lead-magnet signups to the master
# omanut-hakesher list (22958) with per-magnet tags.
# Get from: https://app.responder.live (Settings → API → V2 OAuth)
# If unset, the API still delivers the asset by Resend email.
RAVMESSER_CLIENT_ID=122
RAVMESSER_CLIENT_SECRET=
RAVMESSER_USER_TOKEN=

# ===========================================
# Production URL (used by Next.js metadata)
# Set in Vercel dashboard under Environment Variables
# NEXT_PUBLIC_SITE_URL=https://omanut-hakesher.co.il
# ===========================================
