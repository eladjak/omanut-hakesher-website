# ===========================================
# Environment Variables for Omanut HaKesher
# ===========================================
# Copy this file to .env.local and fill in values

# Google Analytics
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Contact Form - Resend Email Service
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_EMAIL=hello@omanut-hakesher.co.il

# ===========================================
# Rav-Messer (Responder) V2 OAuth — for /api/lead/subscribe
# Account 1001688. Used to add lead-magnet signups to the master
# omanut-hakesher list (22958) with per-magnet tags.
# Names match content-studio env so the same values can be reused.
# Get from: https://app.responder.live (Settings → API → V2 OAuth)
# If unset, the API still delivers the asset by Resend email.
RAV_MESSER_CLIENT_ID=122
RAV_MESSER_CLIENT_SECRET=
RAV_MESSER_USER_TOKEN=

# ===========================================
# Sumit (sumit.co.il) — payment + invoicing
# Replaces Stripe. Single-call charge + Hebrew receipt (קבלה).
# 1.1% credit, no flat fee. Bit + Apple Pay native.
# Get: Sumit dashboard → Settings → Developers → Create API key
# If unset, /api/sumit/checkout returns 503 and UI degrades to /contact.
SUMIT_COMPANY_ID=
SUMIT_API_KEY=
# Webhook secret for verifying /api/sumit/webhook signatures (HMAC-SHA256).
# Get/set: Sumit dashboard → Webhooks → Add endpoint
#   URL = https://omanut-hakesher.co.il/api/sumit/webhook
# If unset, webhook accepts unsigned requests (logs warning) — set before prod!
SUMIT_WEBHOOK_SECRET=

# ===========================================
# Production URL (used by Next.js metadata + Sumit redirect URLs)
# Set in Vercel dashboard under Environment Variables
NEXT_PUBLIC_SITE_URL=https://omanut-hakesher.co.il
# ===========================================
